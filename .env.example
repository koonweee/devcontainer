# Required
# None for local development. Defaults are configured for a zero-config start.

# Optional overrides
# SQLite path used by the orchestrator/API process.
DEVBOX_DB_PATH=/data/devbox.sqlite

# Web server-side URL for reaching the API (SSR/internal fetches).
DEVBOX_INTERNAL_API_URL=http://api:3000

# Web client-visible URL for reaching the API from the browser.
DEVBOX_PUBLIC_API_URL=http://localhost:3000

# CLI API base URL.
DEVBOX_API_URL=http://localhost:3000
